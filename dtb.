Financial Tracking

SELECT
    ID_Tarea AS task_id,
    Proyecto AS project_name,vl
    Modulo AS module,
    Tarea AS task_name,
    Responsable AS responsible,

    CAST(Horas_Estimadas AS FLOAT) AS estimated_hours,
    CAST(Costo_Hora AS FLOAT) AS hourly_cost,

    -- Budget calculation
    CAST(Horas_Estimadas AS FLOAT) * CAST(Costo_Hora AS FLOAT) AS task_budget

FROM project_tasks_raw;
