Execution Tracking)

Clasificas tareas:

Completed

In Progress

Not Started

SQL
-- Normalize task status

SELECT
    ID_Tarea,
    Tarea,

    CASE
        WHEN Estado IN ('Hecho','Done','Completed') THEN 'Completed'
        WHEN Estado IN ('En progreso','In Progress') THEN 'In Progress'
        WHEN Estado IN ('Pendiente','No iniciado') THEN 'Not Started'
        ELSE 'Undefined'
    END AS task_status

FROM project_tasks_raw;
Cálculo progreso del proyecto
SELECT
    COUNT(*) AS total_tasks,

    SUM(CASE WHEN Estado = 'Hecho' THEN 1 ELSE 0 END) AS completed_tasks,

    ROUND(
        SUM(CASE WHEN Estado = 'Hecho' THEN 1 ELSE 0 END) * 1.0 /
        COUNT(*),
        2
    ) AS project_progress

FROM project_tasks_raw;

